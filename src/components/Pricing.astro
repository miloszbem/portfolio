---
import type { LangCopy } from '../i18n/copy'

interface Props {
	pl: LangCopy
	en: LangCopy
}
const { pl, en } = Astro.props

const packages = ['pkg1', 'pkg2', 'pkg3', 'pkg4'] as const
---

<section id="cennik" class="pricing">
	<div class="pricing-inner">
		<div data-reveal class="pricing-header">
			<div class="eyebrow" data-pl={pl.priceEy} data-en={en.priceEy}>{pl.priceEy}</div>
			<h2 class="section-title" data-pl={pl.priceTitle} data-en={en.priceTitle}>{pl.priceTitle}</h2>
		</div>
		<div class="pricing-grid">
			{packages.map((key, i) => {
				const plPkg = pl[key]
				const enPkg = en[key]
				return (
					<div data-reveal data-reveal-d={i % 2 === 1 ? '1' : undefined} class="plan-card border-accent">
						{plPkg.includesNote && (
							<div class="plan-note" data-pl={plPkg.includesNote} data-en={enPkg.includesNote}>{plPkg.includesNote}</div>
						)}
						<div class="plan-name" data-pl={plPkg.name} data-en={enPkg.name}>{plPkg.name}</div>
						{plPkg.price ? (
							<div class="plan-price">
								<span data-pl={plPkg.price} data-en={enPkg.price}>{plPkg.price}</span>{' '}
								<span class="plan-unit" data-pl={pl.net} data-en={en.net}>{pl.net}</span>
							</div>
						) : (
							<div class="plan-price">
								<span data-pl={pl.quote} data-en={en.quote}>{pl.quote}</span>{' '}
								<span class="plan-unit" data-pl={pl.indiv} data-en={en.indiv}>{pl.indiv}</span>
							</div>
						)}
						<div class="plan-sep"></div>
						<div class="plan-label" data-pl={pl.implementationLabel} data-en={en.implementationLabel}>{pl.implementationLabel}</div>
						<div class="plan-desc" data-pl={plPkg.desc} data-en={enPkg.desc}>{plPkg.desc}</div>
						<div class="plan-features">
							{plPkg.checklist.map((item, idx) => (
								<div class="feature"><span class="check">✓</span><span data-pl={item} data-en={enPkg.checklist[idx]}>{item}</span></div>
							))}
						</div>
						<details class="plan-retainer">
							<summary data-pl={pl.careLabel} data-en={en.careLabel}>{pl.careLabel}</summary>
							<div class="retainer-body">
								<div class="retainer-body-inner">
									<div class="plan-desc" data-pl={plPkg.retainerDesc} data-en={enPkg.retainerDesc}>{plPkg.retainerDesc}</div>
									<div class="plan-features">
										{plPkg.retainerChecklist.map((item, idx) => (
											<div class="feature"><span class="check">✓</span><span data-pl={item} data-en={enPkg.retainerChecklist[idx]}>{item}</span></div>
										))}
									</div>
									{plPkg.carePrice && (
										<div class="plan-care-price" data-pl={plPkg.carePrice} data-en={enPkg.carePrice}>{plPkg.carePrice}</div>
									)}
									{key === 'pkg2' && (
										<a href="/miesieczna-analiza" class="plan-analytics-link" data-pl={pl.analyticsCta} data-en={en.analyticsCta}>{pl.analyticsCta}</a>
									)}
								</div>
							</div>
						</details>
					</div>
				)
			})}
		</div>
	</div>
</section>

<style>
	.pricing {
		background: var(--surface);
		padding: 84px 56px;
	}

	.pricing-inner {
		max-width: 1100px;
		margin: 0 auto;
	}

	.pricing-header { margin-bottom: 44px; }

	.eyebrow {
		font-size: 11px;
		letter-spacing: 2px;
		text-transform: uppercase;
		color: var(--accent);
		margin-bottom: 10px;
		font-weight: 600;
	}

	.section-title {
		font-family: var(--display);
		font-size: 40px;
		font-weight: 600;
		letter-spacing: -0.5px;
		line-height: 1.05;
	}

	.pricing-grid {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 14px;
	}

	.plan-card {
		background: var(--bg);
		border: 1px solid var(--border);
		border-radius: 12px;
		padding: 30px;
		border-top-width: 3px;
	}

	.border-accent { border-top-color: var(--accent); }

	.plan-note {
		color: var(--accent);
		font-size: 11px;
		font-weight: 600;
		margin-bottom: 8px;
	}

	.plan-name {
		font-family: var(--display);
		font-size: 20px;
		font-weight: 600;
		margin-bottom: 9px;
	}

	.plan-price {
		font-family: var(--display);
		font-size: 36px;
		font-weight: 700;
		line-height: 1;
		margin-bottom: 22px;
	}

	.plan-unit {
		font-family: var(--display);
		font-size: 18px;
		font-weight: 700;
	}

	.plan-sep {
		height: 1px;
		background: var(--border);
		margin-bottom: 22px;
	}

	.plan-label {
		font-size: 11px;
		letter-spacing: 1.5px;
		text-transform: uppercase;
		color: var(--muted);
		margin-bottom: 10px;
	}

	.plan-desc {
		color: var(--muted);
		font-size: 14px;
		line-height: 1.65;
		margin-bottom: 16px;
	}

	.plan-features {
		display: flex;
		flex-direction: column;
		gap: 9px;
		margin-bottom: 22px;
	}

	.feature {
		display: flex;
		gap: 9px;
		font-size: 13px;
		color: rgba(15, 22, 41, 0.55);
	}

	.check {
		color: var(--accent);
		font-weight: 600;
		flex-shrink: 0;
	}

	.plan-retainer {
		border-top: 1px solid var(--border);
		padding-top: 16px;
	}

	.plan-retainer summary {
		cursor: pointer;
		font-size: 13px;
		font-weight: 600;
		color: var(--text);
	}

	.retainer-body {
		overflow: hidden;
		height: 0;
		transition: height 0.3s ease;
	}

	.plan-retainer[open] .retainer-body {
		height: auto;
	}

	.retainer-body-inner {
		padding-top: 16px;
	}

	.retainer-body .plan-features { margin-bottom: 16px; }

	.plan-care-price {
		font-size: 13px;
		font-weight: 600;
		color: var(--accent);
	}

	.plan-analytics-link {
		display: inline-block;
		font-size: 13px;
		font-weight: 600;
		color: var(--accent);
		text-decoration: none;
		margin-top: 8px;
	}

	.plan-analytics-link:hover {
		text-decoration: underline;
	}

	@media (max-width: 900px) {
		.pricing-grid { grid-template-columns: 1fr; }
	}

	@media (max-width: 768px) {
		.pricing { padding: 64px 16px; }
	}
</style>

<script>
	document.querySelectorAll<HTMLDetailsElement>('.plan-retainer').forEach((details) => {
		const summary = details.querySelector('summary')
		const body = details.querySelector<HTMLElement>('.retainer-body')
		if (!summary || !body) return

		let pendingHandler: (() => void) | null = null

		summary.addEventListener('click', (e) => {
			e.preventDefault()

			if (pendingHandler) {
				body.removeEventListener('transitionend', pendingHandler)
				pendingHandler = null
			}

			if (details.open) {
				const startHeight = body.scrollHeight
				body.style.height = startHeight + 'px'
				requestAnimationFrame(() => {
					body.style.height = '0px'
				})
				pendingHandler = () => {
					details.open = false
					body.style.height = ''
					pendingHandler = null
				}
				body.addEventListener('transitionend', pendingHandler, { once: true })
			} else {
				fetch('/api/track', {
					method: 'POST',
					headers: { 'Content-Type': 'application/json' },
					body: JSON.stringify({ event: 'opieka_miesieczna_open' }),
				}).catch(() => {})

				details.open = true
				const endHeight = body.scrollHeight
				body.style.height = '0px'
				requestAnimationFrame(() => {
					body.style.height = endHeight + 'px'
				})
				pendingHandler = () => {
					body.style.height = ''
					pendingHandler = null
				}
				body.addEventListener('transitionend', pendingHandler, { once: true })
			}
		})
	})
</script>
