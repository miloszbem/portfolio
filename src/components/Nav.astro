---
import type { LangCopy } from '../i18n/copy'

interface Props {
	pl: LangCopy
	en: LangCopy
}
const { pl, en } = Astro.props
---

<nav>
	<a href="/" class="nav-home">home</a>
	<div id="nav-links" class="nav-links">
		<a href="#realizacje" data-pl={pl.navWork} data-en={en.navWork}>{pl.navWork}</a>
		<a href="#uslugi" data-pl={pl.navServ} data-en={en.navServ}>{pl.navServ}</a>
		<a href="#cennik" data-pl={pl.navPrice} data-en={en.navPrice}>{pl.navPrice}</a>
		<a href="#omnie" data-pl={pl.navAbout} data-en={en.navAbout}>{pl.navAbout}</a>
		<a href="#kontakt" data-pl={pl.navContact} data-en={en.navContact}>{pl.navContact}</a>
	</div>
	<div class="nav-right">
		<slot name="lang-switcher" />
		<button class="nav-toggle" type="button" aria-expanded="false" aria-controls="nav-overlay">
			<span class="nav-toggle-icon" aria-hidden="true">
				<span></span>
				<span></span>
				<span></span>
			</span>
		</button>
	</div>
</nav>

<div id="nav-overlay" class="nav-overlay" role="dialog" aria-modal="true" aria-label="Menu">
	<a href="#realizacje" data-pl={pl.navWork} data-en={en.navWork}>{pl.navWork}</a>
	<a href="#uslugi" data-pl={pl.navServ} data-en={en.navServ}>{pl.navServ}</a>
	<a href="#cennik" data-pl={pl.navPrice} data-en={en.navPrice}>{pl.navPrice}</a>
	<a href="#omnie" data-pl={pl.navAbout} data-en={en.navAbout}>{pl.navAbout}</a>
	<a href="#kontakt" data-pl={pl.navContact} data-en={en.navContact}>{pl.navContact}</a>
</div>

<style>
	nav {
		display: flex;
		justify-content: space-between;
		align-items: center;
		position: fixed;
		top: 16px;
		left: 50%;
		transform: translateX(-50%);
		width: calc(100% - 112px);
		max-width: 1100px;
		padding: 14px 24px;
		background: rgba(244, 241, 235, 0.88);
		backdrop-filter: blur(14px);
		border: 1px solid var(--border-med);
		border-radius: 14px;
		box-shadow: 0 4px 20px rgba(15, 22, 41, 0.08);
		z-index: 70;
	}

	.nav-home {
		color: var(--text);
		text-decoration: none;
		font-size: 14px;
		font-weight: 500;
	}

	.nav-links {
		display: flex;
		gap: 24px;
		align-items: center;
	}

	.nav-links a {
		color: var(--muted);
		text-decoration: none;
		font-size: 14px;
		transition: color 0.15s;
	}

	.nav-links a:hover {
		color: var(--text);
	}

	.nav-right {
		display: flex;
		align-items: center;
		gap: 12px;
	}

	.nav-toggle {
		display: none;
		border: 0;
		background: transparent;
		color: var(--text);
		cursor: pointer;
		padding: 4px;
	}

	.nav-toggle-icon {
		width: 18px;
		display: grid;
		gap: 3px;
	}

	.nav-toggle-icon span {
		display: block;
		height: 2px;
		border-radius: 999px;
		background: currentColor;
	}

	.nav-overlay {
		display: none;
	}

	@media (max-width: 768px) {
		nav {
			top: 12px;
			left: 16px;
			right: 16px;
			width: auto;
			transform: none;
			padding: 12px 18px;
			border-radius: 12px;
		}

		.nav-links {
			display: none;
		}

		.nav-toggle {
			display: flex;
			align-items: center;
			justify-content: center;
		}

		.nav-overlay {
			display: flex;
			flex-direction: column;
			position: fixed;
			top: 72px;
			left: 16px;
			right: 16px;
			background: rgba(244, 241, 235, 0.97);
			backdrop-filter: blur(14px);
			border: 1px solid var(--border-med);
			border-radius: 12px;
			box-shadow: 0 8px 28px rgba(15, 22, 41, 0.12);
			z-index: 69;
			pointer-events: none;
			opacity: 0;
			transform: translateY(-6px);
			transition: opacity 0.2s ease, transform 0.2s ease;
			overflow: hidden;
		}

		.nav-overlay.is-open {
			opacity: 1;
			transform: translateY(0);
			pointer-events: auto;
		}

		.nav-overlay a {
			color: var(--muted);
			text-decoration: none;
			font-size: 15px;
			padding: 14px 18px;
			border-bottom: 1px solid var(--border);
			transition: color 0.15s, background 0.15s;
		}

		.nav-overlay a:last-child {
			border-bottom: none;
		}

		.nav-overlay a:hover {
			color: var(--text);
			background: rgba(15, 22, 41, 0.03);
		}
	}
</style>

<script>
	const nav = document.querySelector('nav')
	const toggle = document.querySelector('.nav-toggle')
	const overlay = document.getElementById('nav-overlay')
	const overlayLinks = document.querySelectorAll('#nav-overlay a')

	if (nav && toggle && overlay) {
		const setMenuState = (isOpen: boolean) => {
			overlay.classList.toggle('is-open', isOpen)
			toggle.setAttribute('aria-expanded', String(isOpen))
		}

		toggle.addEventListener('click', (e) => {
			e.stopPropagation()
			setMenuState(!overlay.classList.contains('is-open'))
		})

		document.addEventListener('click', (e) => {
			if (!nav.contains(e.target as Node) && !overlay.contains(e.target as Node)) {
				setMenuState(false)
			}
		})

		overlayLinks.forEach((link) => {
			link.addEventListener('click', () => setMenuState(false))
		})
	}
</script>
