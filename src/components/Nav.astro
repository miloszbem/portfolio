---
import type { LangCopy } from '../i18n/copy'

interface Props {
	pl: LangCopy
	en: LangCopy
}
const { pl, en } = Astro.props
---

<nav>
	<div class="nav-top">
		<a href="/" class="nav-home">home</a>
		<div class="nav-right">
			<slot name="lang-switcher" />
			<button class="nav-toggle" type="button" aria-expanded="false">
				<span class="nav-toggle-icon" aria-hidden="true">
					<span></span>
					<span></span>
					<span></span>
				</span>
			</button>
		</div>
	</div>
	<div class="nav-links">
		<a href="#realizacje" data-pl={pl.navWork} data-en={en.navWork}>{pl.navWork}</a>
		<a href="#uslugi" data-pl={pl.navServ} data-en={en.navServ}>{pl.navServ}</a>
		<a href="#cennik" data-pl={pl.navPrice} data-en={en.navPrice}>{pl.navPrice}</a>
		<a href="#omnie" data-pl={pl.navAbout} data-en={en.navAbout}>{pl.navAbout}</a>
		<a href="#kontakt" data-pl={pl.navContact} data-en={en.navContact}>{pl.navContact}</a>
		<a href="/miesieczna-analiza" data-pl={pl.navAnalytics} data-en={en.navAnalytics}>{pl.navAnalytics}</a>
	</div>
</nav>

<style>
	nav {
		display: flex;
		align-items: center;
		position: fixed;
		top: 16px;
		left: 50%;
		transform: translateX(-50%);
		width: calc(100% - 160px);
		max-width: 1100px;
		padding: 12px 22px;
		background: rgba(244, 241, 235, 0.88);
		backdrop-filter: blur(14px);
		border: 1px solid var(--border-med);
		border-radius: 999px;
		box-shadow: 0 4px 20px rgba(15, 22, 41, 0.08);
		z-index: 70;
		transition: border-radius 0.25s ease;
	}

	.nav-top {
		display: contents;
	}

	.nav-home {
		color: var(--text);
		text-decoration: none;
		font-size: 14px;
		font-weight: 500;
		order: 1;
	}

	.nav-links {
		display: flex;
		gap: 24px;
		align-items: center;
		order: 2;
		flex: 1;
		justify-content: center;
	}

	.nav-links a {
		color: var(--muted);
		text-decoration: none;
		font-size: 14px;
		transition: color 0.15s;
	}

	.nav-links a:hover {
		color: var(--text);
	}

	.nav-right {
		display: flex;
		align-items: center;
		gap: 12px;
		order: 3;
	}

	.nav-toggle {
		display: none;
		border: 0;
		background: transparent;
		color: var(--text);
		cursor: pointer;
		padding: 4px;
	}

	.nav-toggle-icon {
		width: 18px;
		display: grid;
		gap: 3px;
	}

	.nav-toggle-icon span {
		display: block;
		height: 2px;
		border-radius: 999px;
		background: currentColor;
	}

	@media (max-width: 768px) {
		nav {
			top: 12px;
			left: 20px;
			right: 20px;
			width: auto;
			transform: none;
			padding: 11px 18px;
			flex-direction: column;
			align-items: stretch;
			border-radius: 20px;
		}

		nav.is-open {
			border-radius: 20px;
		}

		.nav-top {
			display: flex;
			justify-content: space-between;
			align-items: center;
		}

		.nav-home {
			order: unset;
		}

		.nav-right {
			order: unset;
		}

		.nav-links {
			order: unset;
			flex-direction: column;
			align-items: flex-start;
			gap: 0;
			flex: unset;
			justify-content: unset;
			max-height: 0;
			overflow: hidden;
			transition: max-height 0.28s ease;
		}

		nav.is-open .nav-links {
			max-height: 280px;
		}

		.nav-links a {
			padding: 12px 0;
			border-bottom: 1px solid var(--border);
			width: 100%;
			font-size: 15px;
		}

		.nav-links a:last-child {
			border-bottom: none;
		}

		.nav-toggle {
			display: flex;
			align-items: center;
		}
	}
</style>

<script>
	const nav = document.querySelector('nav')
	const toggle = document.querySelector('.nav-toggle')
	const links = document.querySelectorAll('.nav-links a')

	if (nav && toggle) {
		const setMenuState = (isOpen: boolean) => {
			nav.classList.toggle('is-open', isOpen)
			toggle.setAttribute('aria-expanded', String(isOpen))
		}

		toggle.addEventListener('click', (e) => {
			e.stopPropagation()
			setMenuState(!nav.classList.contains('is-open'))
		})

		document.addEventListener('click', (e) => {
			if (!nav.contains(e.target as Node)) {
				setMenuState(false)
			}
		})

		links.forEach((link) => {
			link.addEventListener('click', () => setMenuState(false))
		})
	}
</script>
